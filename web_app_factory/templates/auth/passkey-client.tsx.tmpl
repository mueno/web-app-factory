'use client'

// src/components/auth/passkey-buttons.tsx
// Client-side passkey (WebAuthn) UI component.
//
// Passkey is the PRIMARY authentication method (per product decision).
// This component renders prominently above the OAuth provider buttons.
//
// Registration flow:
//   1. POST /api/auth/passkey/register  -> get registration options
//   2. startRegistration(options)       -> browser presents passkey UI
//   3. POST /api/auth/passkey/register  -> send attestation for verification
//
// Authentication flow:
//   1. POST /api/auth/passkey/authenticate  -> get authentication options
//   2. startAuthentication(options)         -> browser presents passkey UI
//   3. POST /api/auth/passkey/authenticate  -> send assertion for verification
//   4. Set session tokens from response, redirect to returnTo

import { startRegistration, startAuthentication } from '@simplewebauthn/browser'
import { useCallback, useState } from 'react'
import { useRouter } from 'next/navigation'

interface PasskeyButtonsProps {
  /** User's email address (required for passkey registration / lookup). */
  email?: string
  /** User ID (Supabase UUID). Required for registration; optional for authentication. */
  userId?: string
  /** Path to redirect to after successful authentication. Defaults to '/'. */
  returnTo?: string
  /** Whether to show the registration button (for sign-up flows). */
  showRegister?: boolean
}

type PasskeyError =
  | 'NotAllowedError'     // User cancelled or timed out
  | 'SecurityError'        // Domain / RP ID mismatch
  | 'InvalidStateError'    // Credential already registered
  | 'UnknownError'

function mapPasskeyError(err: unknown): string {
  if (err instanceof Error) {
    if (err.name === 'NotAllowedError') {
      return 'Passkey sign-in was cancelled. Please try again.'
    }
    if (err.name === 'SecurityError') {
      return 'Passkey failed due to a security configuration issue. Please contact support.'
    }
    if (err.name === 'InvalidStateError') {
      return 'A passkey for this account is already registered on this device.'
    }
    return err.message
  }
  return 'An unexpected error occurred. Please try again.'
}

export default function PasskeyButtons({
  email,
  userId,
  returnTo = '/',
  showRegister = false,
}: PasskeyButtonsProps): React.ReactElement {
  const router = useRouter()
  const [isRegistering, setIsRegistering] = useState(false)
  const [isAuthenticating, setIsAuthenticating] = useState(false)
  const [error, setError] = useState<string | null>(null)
  const [success, setSuccess] = useState<string | null>(null)

  // ---------------------------------------------------------------------------
  // Registration flow
  // ---------------------------------------------------------------------------
  const handleRegister = useCallback(async () => {
    if (!userId || !email) {
      setError('Email and user ID are required to register a passkey.')
      return
    }

    setIsRegistering(true)
    setError(null)
    setSuccess(null)

    try {
      // Phase 1: Get registration options from the server
      const optionsRes = await fetch('/api/auth/passkey/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, email }),
      })

      if (!optionsRes.ok) {
        const { error: apiError } = await optionsRes.json().catch(() => ({}))
        throw new Error(apiError ?? 'Failed to get registration options')
      }

      const registrationOptions = await optionsRes.json()

      // Phase 2a: Browser WebAuthn API — user interacts with their authenticator
      const attestation = await startRegistration({ optionsJSON: registrationOptions })

      // Phase 2b: Send attestation to server for verification and storage
      const verifyRes = await fetch('/api/auth/passkey/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, email, response: attestation }),
      })

      if (!verifyRes.ok) {
        const { error: apiError } = await verifyRes.json().catch(() => ({}))
        throw new Error(apiError ?? 'Passkey registration failed')
      }

      setSuccess('Passkey registered successfully! You can now sign in with your passkey.')
    } catch (err) {
      setError(mapPasskeyError(err))
    } finally {
      setIsRegistering(false)
    }
  }, [userId, email])

  // ---------------------------------------------------------------------------
  // Authentication flow
  // ---------------------------------------------------------------------------
  const handleAuthenticate = useCallback(async () => {
    setIsAuthenticating(true)
    setError(null)
    setSuccess(null)

    try {
      // Phase 1: Get authentication options (server looks up registered credentials)
      const optionsRes = await fetch('/api/auth/passkey/authenticate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, userId }),
      })

      if (!optionsRes.ok) {
        const { error: apiError } = await optionsRes.json().catch(() => ({}))
        throw new Error(apiError ?? 'Failed to get authentication options')
      }

      const authenticationOptions = await optionsRes.json()

      // Phase 2a: Browser WebAuthn API — user authenticates with their passkey
      const assertion = await startAuthentication({ optionsJSON: authenticationOptions })

      // Phase 2b: Send assertion to server for verification and session creation
      const verifyRes = await fetch('/api/auth/passkey/authenticate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, userId, response: assertion }),
      })

      if (!verifyRes.ok) {
        const { error: apiError } = await verifyRes.json().catch(() => ({}))
        throw new Error(apiError ?? 'Passkey authentication failed')
      }

      const { session } = await verifyRes.json()

      // Store session tokens in localStorage so Supabase client picks them up
      if (session?.accessToken) {
        localStorage.setItem('supabase.auth.token', JSON.stringify({
          access_token: session.accessToken,
          refresh_token: session.refreshToken,
        }))
      }

      // Redirect to the originally requested page
      router.push(returnTo)
    } catch (err) {
      setError(mapPasskeyError(err))
    } finally {
      setIsAuthenticating(false)
    }
  }, [email, userId, returnTo, router])

  const isLoading = isRegistering || isAuthenticating

  return (
    <div className="flex flex-col gap-3">
      {/* Primary action: Sign in with Passkey */}
      <button
        onClick={handleAuthenticate}
        disabled={isLoading}
        className="flex items-center justify-center gap-2 rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
        aria-label="Sign in with passkey"
      >
        {/* Fingerprint / key icon */}
        <svg
          className="h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          strokeWidth={2}
          aria-hidden="true"
        >
          <path
            strokeLinecap="round"
            strokeLinejoin="round"
            d="M12 11c0-1.1.9-2 2-2s2 .9 2 2v.5M8 11c0-2.2 1.8-4 4-4s4 1.8 4 4M6 21c0-3.3 2.7-6 6-6s6 2.7 6 6M12 18v3"
          />
          <circle cx="12" cy="11" r="1" fill="currentColor" />
        </svg>
        {isAuthenticating ? 'Verifying…' : 'Sign in with Passkey'}
      </button>

      {/* Optional: Register a new passkey (shown on sign-up or account settings) */}
      {showRegister && (
        <button
          onClick={handleRegister}
          disabled={isLoading}
          className="flex items-center justify-center gap-2 rounded-xl border border-indigo-300 bg-white px-6 py-3 text-sm font-semibold text-indigo-700 hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
          aria-label="Register a new passkey"
        >
          <svg
            className="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            strokeWidth={2}
            aria-hidden="true"
          >
            <path
              strokeLinecap="round"
              strokeLinejoin="round"
              d="M12 4v16m8-8H4"
            />
          </svg>
          {isRegistering ? 'Registering…' : 'Register Passkey'}
        </button>
      )}

      {/* Error message */}
      {error && (
        <p className="text-center text-sm text-red-600" role="alert">
          {error}
        </p>
      )}

      {/* Success message */}
      {success && (
        <p className="text-center text-sm text-green-700" role="status">
          {success}
        </p>
      )}
    </div>
  )
}
