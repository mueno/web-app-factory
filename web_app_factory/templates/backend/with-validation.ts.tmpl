// src/lib/api/with-validation.ts — generated by web-app-factory
// Demonstrates the Zod safeParse + standardized error response pattern.
// Used as a reference template by the build agent when generating route handlers.
//
// Pattern:
//   1. Import Zod and define schema BEFORE the handler
//   2. Use schema.safeParse() — never schema.parse() (which throws)
//   3. Return { error: string, code: string } on validation failure
//   4. Access only validated data in handler body

import { z } from "zod";
import { apiError } from "@/lib/api/errors";

/**
 * Generic validation wrapper.
 *
 * Usage example in a route handler:
 *
 *   const CreateItemSchema = z.object({
 *     name: z.string().min(1).max(255),
 *     quantity: z.number().int().positive(),
 *   });
 *
 *   export async function POST(request: Request): Promise<Response> {
 *     const bodyRaw = await request.json();
 *     const parsed = CreateItemSchema.safeParse(bodyRaw);
 *
 *     if (!parsed.success) {
 *       return apiError(
 *         parsed.error.issues[0]?.message ?? "Validation failed",
 *         "VALIDATION_ERROR",
 *         422,
 *       );
 *     }
 *
 *     // parsed.data is now fully typed and validated
 *     const { name, quantity } = parsed.data;
 *     // ... database operations ...
 *   }
 */

/**
 * withValidation — higher-order helper for request body validation.
 *
 * Parses the request body with the provided Zod schema and calls the
 * handler with the validated data. Returns a 422 error response if
 * validation fails.
 *
 * @param schema  - Zod schema to validate the request body against
 * @param request - Incoming Request object
 * @param handler - Async function receiving validated data and returning a Response
 */
export async function withValidation<T>(
  schema: z.ZodType<T>,
  request: Request,
  handler: (data: T) => Promise<Response>,
): Promise<Response> {
  let bodyRaw: unknown;
  try {
    bodyRaw = await request.json();
  } catch {
    return apiError("Request body must be valid JSON", "INVALID_JSON", 400);
  }

  const parsed = schema.safeParse(bodyRaw);
  if (!parsed.success) {
    return apiError(
      parsed.error.issues[0]?.message ?? "Validation failed",
      "VALIDATION_ERROR",
      422,
    );
  }

  return handler(parsed.data);
}
